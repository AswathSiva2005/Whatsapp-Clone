# Backend API endpoint
REACT_APP_API_ENDPOINT="http://localhost:5000/api/v1"

# Cloudinary Configuration (REQUIRED for image uploads in register)
# Get these from: https://cloudinary.com/console/settings/credentials
# IMPORTANT: Use CLOUD_NAME2 and CLOUD_SECRET2 (not the old CLOUD_NAME/CLOUD_SECRET)
# The app validates config and uses backend fallback if credentials are invalid
REACT_APP_CLOUD_NAME2="your-actual-cloud-name-here"
REACT_APP_CLOUD_SECRET2="your-actual-upload-preset-here"

# Old variables (ignored - kept for backward compatibility)
REACT_APP_CLOUD_SECRET="put-same-secret-here"
REACT_APP_CLOUD_NAME="put-same-name-here"
